#!/bin/bash

echo "Checking WireGuard dependencies ..."

if ! command -v wg >/dev/null 2>&1; then
    echo "WireGuard tools (wg) not found. Please install wireguard-tools on the host system." > "${TRIM_TEMP_LOGFILE}"
    exit 1
fi

if ! command -v wg-quick >/dev/null 2>&1; then
    echo "wg-quick not found. Please install wireguard-tools on the host system." > "${TRIM_TEMP_LOGFILE}"
    exit 1
fi

if ! ip link add dev wg0-check type wireguard 2>/dev/null; then
    echo "WireGuard kernel module not available. Ensure the wireguard kernel module is loaded (modprobe wireguard)." > "${TRIM_TEMP_LOGFILE}"
    exit 1
fi
ip link del dev wg0-check 2>/dev/null

exit 0
