#!/bin/bash

ETC_DIR="${TRIM_PKGETC}"
VAR_DIR="${TRIM_PKGVAR}"

mkdir -p "${ETC_DIR}" "${VAR_DIR}"

if [ ! -f "${VAR_DIR}/state.json" ]; then
    wg genkey > "${VAR_DIR}/.private_key" 2>/dev/null
    private_key=$(cat "${VAR_DIR}/.private_key" 2>/dev/null)
    echo "${private_key}" | wg pubkey > "${VAR_DIR}/.public_key" 2>/dev/null

    cat > "${VAR_DIR}/state.json" <<STATE
{
  "interface": {
    "address": "",
    "listenPort": 0,
    "privateKey": "${private_key}",
    "dns": "",
    "mtu": 0,
    "table": "auto",
    "preUp": "",
    "postUp": "",
    "preDown": "",
    "postDown": "",
    "saveConfig": false
  },
  "peers": []
}
STATE
    rm -f "${VAR_DIR}/.private_key" "${VAR_DIR}/.public_key"
    echo "Initial state created with auto-generated server key."
fi

chmod 600 "${VAR_DIR}/state.json" 2>/dev/null

echo "WireGuard UI installed. Access via desktop icon or /app/fn-wireguard."
log_file="${TRIM_PKGVAR}/info.log"
echo "$(date '+%Y-%m-%d %H:%M:%S') - INSTALL: first-time setup complete" >> "${log_file}"

exit 0
