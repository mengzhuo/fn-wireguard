#!/bin/bash

LOG_FILE="${TRIM_PKGVAR}/info.log"
PID_FILE="${TRIM_PKGVAR}/app.pid"
BIN="${TRIM_APPDEST}/wireguard-ui"
SOCK="${TRIM_APPDEST}/app.sock"
GATEWAY="/app/fn-wireguard"

export GATEWAY_PREFIX="${GATEWAY}"
export SOCKET_PATH="${SOCK}"

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "${LOG_FILE}"
}

start_process() {
    if status; then
        return 0
    fi

    if [ ! -f "${BIN}" ]; then
        echo "Binary not found: ${BIN}" > "${TRIM_TEMP_LOGFILE}"
        log_msg "ERROR: ${BIN} not found"
        exit 1
    fi

    log_msg "Starting WireGuard UI (gateway=${GATEWAY}, socket=${SOCK}) ..."
    "${BIN}" >> "${LOG_FILE}" 2>&1 &
    printf "%s" "$!" > "${PID_FILE}"
    log_msg "PID=$!"
    return 0
}

stop_process() {
    log_msg "Stopping process ..."

    if [ ! -r "${PID_FILE}" ]; then
        return 0
    fi

    pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
    if ! kill -0 "${pid}" 2>/dev/null; then
        rm -f "${PID_FILE}"
        return 0
    fi

    log_msg "Sending TERM to PID:${pid}..."
    kill -TERM "${pid}" 2>/dev/null

    local count=0
    while kill -0 "${pid}" 2>/dev/null && [ $count -lt 10 ]; do
        sleep 1
        count=$((count + 1))
    done

    if kill -0 "${pid}" 2>/dev/null; then
        log_msg "Sending KILL to PID:${pid}..."
        kill -KILL "${pid}" 2>/dev/null
        sleep 1
    fi

    rm -f "${PID_FILE}" "${SOCK}"
    log_msg "Process stopped"
    return 0
}

status() {
    if [ -f "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if kill -0 "${pid}" 2>/dev/null; then
            return 0
        fi
        rm -f "${PID_FILE}"
        rm -f "${SOCK}"
    fi
    return 1
}

case $1 in
start)
    start_process
    ;;
stop)
    stop_process
    ;;
status)
    if status; then
        exit 0
    else
        exit 3
    fi
    ;;
*)
    exit 1
    ;;
esac
